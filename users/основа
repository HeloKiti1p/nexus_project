<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Nexus{% endblock %}</title>
    {% load static %}
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Твой собственный CSS (если нужно что-то переопределить) -->
    <link rel="stylesheet" href="{% static 'css/style.css' %}">

</head>
<body>
    <!-- Навигационная панель Bootstrap -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
<a class="navbar-brand" href="{% url 'posts:list' %}">Nexus</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a href="{% url 'posts:list' %}">Главная</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{% url 'about' %}">О проекте</a>
                    </li>
                    {% if user.is_authenticated %}
                        <li class="nav-item">
                            <span class="nav-link disabled">Привет, {{ user.username }}!</span>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>
    {% if user.is_authenticated %}
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
            {% if user.avatar %}
                <img src="{{ user.avatar.url }}" alt="Аватар" class="rounded-circle me-1" style="width: 30px; height: 30px; object-fit: cover;">
            {% else %}
                <i class="bi bi-person-circle me-1" style="font-size: 1.8rem;"></i>
            {% endif %}
            <span>{{ user.username }}</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="{% url 'users:profile' user.username %}"><i class="bi bi-person me-2"></i>Мой профиль</a></li>
            <a href="{% url 'posts:create' %}" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Создать новый пост
            </a>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="{% url 'users:logout' %}"><i class="bi bi-box-arrow-right me-2"></i>Выйти</a></li>
        </ul>
    </li>
{% else %}
    <li class="nav-item">
        <a class="nav-link" href="{% url 'users:login' %}"><i class="bi bi-box-arrow-in-right me-1"></i>Войти</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="{% url 'users:register' %}"><i class="bi bi-person-plus me-1"></i>Регистрация</a>
    </li>
{% endif %}
    <!-- Основной контейнер для контента -->
    <main class="container mt-4">
        {% block content %}
        <!-- Здесь будет уникальное содержимое страниц -->
        {% endblock %}
    </main>

    <footer class="bg-light text-center text-muted py-3 mt-5">
        <div class="container">
            <p>2026 Реализация соц.сети Nexus</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
